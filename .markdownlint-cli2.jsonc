{
  "globs": ["**/*.md"],
  "ignores": [
    "**/node_modules/**",
    "**/dist/**",
    "coverage/**",
    ".fil/**",
    "**/CHANGELOG.md",
    ".changeset/**/*.md",
    "CODE_OF_CONDUCT.md"
  ],
  "config": {
    "default": true,
    "MD013": false,
    "MD024": { "siblings_only": true },
    "MD033": false,
    "MD041": false,
    "MD059": false,
    "MD060": false
  }
}
