{
  "name": "@color-sunset/fil-contract",
  "version": "0.1.0",
  "description": "The .fil/run.json schema plus serializers/validators — the single source of truth every Adapter reads.",
  "license": "MIT",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "main": "./dist/index.js",
