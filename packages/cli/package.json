{
  "name": "@fil/cli",
  "version": "0.0.0",
  "description": "The `fil` CLI: a thin wiring over the Fil modules.",
  "license": "MIT",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "bin": {
    "fil": "./dist/index.js"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc -b",
    "typecheck": "tsc --noEmit -p tsconfig.json"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/RemyFevry/fil.git",
    "directory": "packages/cli"
  },
  "homepage": "https://github.com/RemyFevry/fil",
  "bugs": {
    "url": "https://github.com/RemyFevry/fil/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@fil/contract": "workspace:*",
    "@fil/engine": "workspace:*",
    "@fil/evolution": "workspace:*",
    "@fil/flow-loader": "workspace:*",
    "@fil/gate-runner": "workspace:*",
    "@fil/inspect-view": "workspace:*",
    "@fil/orchestrator": "workspace:*",
    "@fil/store": "workspace:*"
  }
}