{
  "name": "@color-sunset/fil-engine",
  "version": "0.2.0",
  "description": "The FlowEngine seam (ADR-0003) and the default XState implementation (ADR-0002).",
  "license": "MIT",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./flows": {
      "types": "./dist/flows/index.d.ts",
      "import": "./dist/flows/index.js"
    }
  },
  "scripts": {
    "build": "tsc -b",
    "typecheck": "tsc --noEmit -p tsconfig.json"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/RemyFevry/fil.git",
    "directory": "packages/engine"
  },
  "homepage": "https://github.com/RemyFevry/fil",
  "bugs": {
    "url": "https://github.com/RemyFevry/fil/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@color-sunset/fil-contract": "workspace:*",
    "@statelyai/inspect": "^0.7.2",
    "xstate": "^5.18.0"
  }
}