{
  "name": "@color-sunset/fil-orchestrator",
  "version": "0.1.0",
  "description": "startRun / advance / back / cancel — drives the Flow via the engine and gate-runner, persists through the store.",
  "license": "MIT",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc -b",
    "typecheck": "tsc --noEmit -p tsconfig.json"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/RemyFevry/fil.git",
    "directory": "packages/orchestrator"
  },
  "homepage": "https://github.com/RemyFevry/fil",
  "bugs": {
    "url": "https://github.com/RemyFevry/fil/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@color-sunset/fil-contract": "workspace:*",
    "@color-sunset/fil-engine": "workspace:*",
    "@color-sunset/fil-gate-runner": "workspace:*",
    "@color-sunset/fil-store": "workspace:*"
  }
}