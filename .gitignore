# Dependencies
node_modules/

# Build output
dist/
*.tsbuildinfo

# Test coverage
coverage/

# Test scratch directories (CLI tests put their .fil/ trees under here)
.tmp/

# Temp dirs created by the dynamic-`import()` flow loader. They live under
# `process.cwd()` (see ADR-0005 §Windows URL normalization — required to
# sidestep the Windows 8.3 short-name alias on `os.tmpdir()`), so the
# cleanup-in-finally path can occasionally leave them behind on a hard kill.
# The consolidated dance in `packages/flow-loader/src/index.ts` uses the
# `.fil-flow-loader-*` prefixes; `.fil-pi-tool-surface-*` is the test harness
# in `packages/pi-adapter/test/tool-surface.test.ts`.
.fil-flow-loader-*/
.fil-pi-tool-surface-*/

# Fil local work-in-progress (durable state — never committed)
.fil/runs/
.fil/run.json
.fil/proposals/

# Environment / OS
.DS_Store
.env
.env.local
*.log

# Editor
.vscode/*
!.vscode/extensions.json
.idea/
