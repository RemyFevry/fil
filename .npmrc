# pnpm workspace settings for the Fil monorepo.
#
# These defaults make `pnpm add @fil/<x> -w` save a `workspace:*` reference (so
# dev edits flow through without bumping versions), and tell pnpm to link
# workspace packages into `node_modules/` rather than fetching from the registry
# when the same package is already in the workspace.

# --- Workspace / install behaviour ------------------------------------------
link-workspace-packages=true
prefer-workspace-packages=true
save-workspace-protocol=workspace:*
shared-workspace-lockfile=true
auto-install-peers=true
strict-peer-dependencies=false

# --- Publish -----------------------------------------------------------------
# `provenance=true` is intentionally NOT set here. npm's provenance signing
# only works inside GitHub Actions (it needs the OIDC environment) and would
# break any local `pnpm publish` with:
#   EUSAGE Automatic provenance generation not supported for provider: null
# The release workflow (.github/workflows/release.yml) sets
# `NPM_CONFIG_PROVENANCE: 'true'` in its env, so CI publishes attach provenance
# while local manual publishes (e.g. the first release) work as plain token
# publishes.