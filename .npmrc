# pnpm workspace settings for the Fil monorepo.
#
# These defaults make `pnpm add @fil/<x> -w` save a `workspace:*` reference (so
# dev edits flow through without bumping versions), and tell pnpm to link
# workspace packages into `node_modules/` rather than fetching from the registry
# when the same package is already in the workspace.

# --- Workspace / install behaviour ------------------------------------------
link-workspace-packages=true
prefer-workspace-packages=true
save-workspace-protocol=workspace:*
shared-workspace-lockfile=true
auto-install-peers=true
strict-peer-dependencies=false

# --- Publish -----------------------------------------------------------------
# `changeset publish` does NOT forward `--provenance` (its own CLI rejects the
# flag), so we ask pnpm to attach npm provenance to every publish via this
# project-level config. Works on pnpm 7.18+ and npm 9.5+. See:
#   https://docs.npmjs.com/generating-provenance-statements
provenance=true