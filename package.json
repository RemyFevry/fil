{
  "name": "fil-cli",
  "version": "0.0.0",
  "description": "An open-source harness for agentic software-development lifecycles.",
  "license": "MIT",
  "type": "module",
  "packageManager": "pnpm@10.32.1",
  "engines": {
    "node": ">=20"
  },
  "bin": {
    "fil": "./packages/cli/dist/index.js"
  },
  "files": [
    "packages/cli/dist",
    "LICENSE",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -b",
    "build:clean": "tsc -b --clean && tsc -b",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit -p tsconfig.check.json",
    "lint": "eslint .",
    "lint:md": "markdownlint-cli2",
    "ci": "pnpm run lint && pnpm run lint:md && pnpm run build && pnpm run typecheck && pnpm run test",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "release": "pnpm build && changeset publish --provenance",
    "pre-enter": "changeset pre enter",
    "pre-exit": "changeset pre exit",
    "release:alpha": "pnpm pre-enter alpha && pnpm version-packages && pnpm build && changeset publish --provenance --tag alpha",
    "release:beta": "pnpm pre-enter beta && pnpm version-packages && pnpm build && changeset publish --provenance --tag beta"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/RemyFevry/fil.git"
  },
  "homepage": "https://github.com/RemyFevry/fil",
  "bugs": {
    "url": "https://github.com/RemyFevry/fil/issues"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "dependencies": {
    "@fil/cli": "workspace:*",
    "@fil/contract": "workspace:*",
    "@fil/engine": "workspace:*",
    "@fil/evolution": "workspace:*",
    "@fil/flow-loader": "workspace:*",
    "@fil/gate-runner": "workspace:*",
    "@fil/inspect-view": "workspace:*",
    "@fil/orchestrator": "workspace:*",
    "@fil/store": "workspace:*"
  },
  "devDependencies": {
    "@changesets/cli": "^2.27.0",
    "@eslint/js": "^9.39.4",
    "@types/node": "^22.10.0",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "@vitest/coverage-v8": "^2.1.0",
    "eslint": "^9.0.0",
    "markdownlint-cli2": "^0.22.1",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.62.1",
    "vitest": "^2.1.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild"
    ]
  }
}